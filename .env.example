# ============================================================
# WE ARE AJ DIGITAL — environment variable reference
#
# Two ways to supply these locally:
#   1. Doppler (recommended) — secrets live in the `weareajdigital-com`
#      project. Run `doppler setup` once, then `npm run dev` (scripts are
#      wrapped with `doppler run`). Seed the dev config from this file:
#        doppler secrets upload .env.example --project weareajdigital-com --config dev
#   2. .env.local — copy this file to .env.local and fill in real values.
#      Next.js auto-loads it; works without Doppler.
#
# NEVER commit .env.local — only this file gets committed.
# ============================================================

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://www.weareajdigital.com

# ------------------------------------------------------------
# SUPABASE — https://app.supabase.com/project/oirwjereckojomuwinvg/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct DB (migrations / scripts only — NOT used at runtime)
SUPABASE_DB_URL=

# ------------------------------------------------------------
# EMAIL — Resend https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=
APPLY_NOTIFICATION_EMAIL=
EMAIL_FROM=
# Optional — if set, diagnostic results POST to this URL instead of email
DIAGNOSTIC_WEBHOOK_URL=

# ------------------------------------------------------------
# CMS — Sanity https://www.sanity.io/manage/project/1k82n5rq/api
# ------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-04
SANITY_API_READ_TOKEN=

# ------------------------------------------------------------
# ANALYTICS / INTEGRATIONS (optional)
# ------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_ENABLE_ANALYTICS=false
